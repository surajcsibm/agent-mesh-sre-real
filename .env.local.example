# ── Agent Mesh SRE — Environment Config ──────────────────────────────────────
# Copy this file to .env.local and fill in your credentials.
# The app works in MOCK mode without any credentials — all scenarios run on the
# in-memory event bus. Set KAFKA_MODE=real and the KAFKA_* vars below to wire
# it to a real Kafka cluster.

# ── Kafka mode ────────────────────────────────────────────────────────────────
# mock  — in-memory simulation only (default, no Kafka broker needed)
# real  — connect to a real Kafka cluster (Strimzi on GKE, or Confluent Cloud)
KAFKA_MODE=mock

# ── Cluster identity (used by the Setup Wizard and snapshot API) ──────────────
KAFKA_NAMESPACE=agent-mesh-sre
KAFKA_CLUSTER=agent-mesh-kafka

# ── Option A: Strimzi on GKE (recommended — see deploy/gke/) ─────────────────
#
# How to get these values after running install-gke.sh --wait:
#   ./deploy/scripts/get-credentials-gke.sh > .env.local
#
# The script populates all four vars below automatically.
#
# KAFKA_BOOTSTRAP         External LoadBalancer bootstrap, e.g. 34.70.12.34:9094
# KAFKA_USERNAME          SCRAM user (default: agent-mesh-controller)
# KAFKA_PASSWORD          SCRAM password (generated by Strimzi User Operator)
# KAFKA_CA_CERT_BASE64    Base64-encoded cluster CA PEM (for TLS verification)
#
KAFKA_BOOTSTRAP=34.70.0.0:9094
KAFKA_USERNAME=agent-mesh-controller
KAFKA_PASSWORD=your-scram-password-here
KAFKA_CA_CERT_BASE64=your-base64-ca-cert-here

# ── Option B: RedPanda Cloud Serverless (free forever, no credit card) ────────
#
# Sign up at https://cloud.redpanda.com → create a Serverless cluster (free).
# See deploy/redpanda/SETUP.md for the full walkthrough.
# Then run:  ./deploy/scripts/configure-redpanda.sh
#
# KAFKA_BOOTSTRAP=seed-xxxxxxxx.cloud.redpanda.com:9092
# KAFKA_USERNAME=agent-mesh-controller
# KAFKA_PASSWORD=your-redpanda-password
# KAFKA_SASL_MECHANISM=scram-sha-256
# (no KAFKA_CA_CERT_BASE64 — RedPanda uses public Let's Encrypt certs)

# ── Option C: Confluent Cloud ─────────────────────────────────────────────────
#
# How to get these values:
#   1. https://confluent.cloud → your Cluster → Cluster Settings → Bootstrap
#   2. API Keys → Create Key → Global access → copy Key + Secret
#
# Note: Confluent Cloud uses SASL/PLAIN; the runtime auto-detects the mechanism
# from the absence of KAFKA_CA_CERT_BASE64 and falls back to plain+SSL.
#
# KAFKA_BOOTSTRAP=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
# KAFKA_USERNAME=your-confluent-api-key
# KAFKA_PASSWORD=your-confluent-api-secret
# (no KAFKA_CA_CERT_BASE64 needed — Confluent uses public CAs)

# ── Kafka topics ──────────────────────────────────────────────────────────────
# These are pre-created by deploy/base/03-kafka-topics.yaml (Strimzi) or must
# be created manually in Confluent Cloud before setting KAFKA_MODE=real.
#
# ops.requests.v1         1 partition  (6 on OpenShift base)  retention 7d
# ops.kafka.metrics.v1    1 partition                         retention 1d
# ops.incidents.v1        1 partition                         retention 30d
# ops.actions.audit.v1    1 partition                         retention 365d
# ops.lessons.v1          1 partition                         compacted
# ops.notifications.v1    1 partition                         retention 7d
# demo.payments.events    1 partition                         retention 3d

# ── SMTP (required for email notifications) ───────────────────────────────────
# Gmail (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here

# ── Recipient ─────────────────────────────────────────────────────────────────
NOTIFICATION_EMAIL=surajcs@gmail.com

# ── How to set up Gmail App Password ─────────────────────────────────────────
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification (required for App Passwords)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create an App Password → select "Mail" and "Other" → name it "agent-mesh-sre"
# 5. Copy the 16-character password into SMTP_PASS above
#
# ── Alternative SMTP providers ───────────────────────────────────────────────
#
# Outlook / Office 365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
#
# Amazon SES:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587  SMTP_SECURE=false
#
# Mailhog (local dev, no credentials needed):
#   SMTP_HOST=localhost  SMTP_PORT=1025  SMTP_SECURE=false
